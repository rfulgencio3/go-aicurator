# === IA ===
# Provedor: openai (padrão) | anthropic
AI_PROVIDER=openai

# OpenAI (usar quando AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                        # opcional, esse é o padrão

# Anthropic (usar quando AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514   # opcional, esse é o padrão

# === E-mail ===
# Provedor: resend (padrão) | sendgrid
EMAIL_PROVIDER=resend

# Resend (usar quando EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_...

# SendGrid (usar quando EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG....

EMAIL_FROM=seuemail@dominio.com
EMAIL_FROM_NAME=Agente de Curadoria        # opcional
EMAIL_TO=voce@email.com,outro@email.com    # vírgula para múltiplos destinatários

# === Curadoria ===
# Tópicos separados por vírgula
TOPICS=Inteligência Artificial,Machine Learning,LLMs e modelos de linguagem,Startups de tecnologia

# Formatos separados por vírgula
FORMATS=Artigos e notícias,Papers acadêmicos,Vídeos e podcasts

# Quantidade de itens no digest (padrão: 12)
ITEM_QTY=12

# Idioma do digest: pt | en | bilingual (padrão: bilingual)
LANG=bilingual
