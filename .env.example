# === IA ===
# Provedor: openai (padrão) | anthropic
AI_PROVIDER=openai

# OpenAI (usar quando AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                        # opcional, esse é o padrão

# Anthropic (usar quando AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514   # opcional, esse é o padrão

# === E-mail ===
# Provedor: resend (padrão) | sendgrid
EMAIL_PROVIDER=resend

# Resend (usar quando EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_...

# SendGrid (usar quando EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG....

EMAIL_FROM=seuemail@dominio.com
EMAIL_FROM_NAME=Metria CuradorIA           # opcional, esse é o padrão
EMAIL_TO=voce@email.com,outro@email.com    # vírgula para múltiplos destinatários

# === Curadoria ===
# Tópicos separados por vírgula (o padrão cobre 10 áreas)
TOPICS=Estruturas de Dados e Algoritmos,Inteligência Artificial e Machine Learning,LLMs e Modelos de Linguagem,Astronomia e Exploração Espacial,Neurociência e Comportamento Humano,Estoicismo e Filosofia Prática,Desenvolvimento Pessoal e Performance,Geopolítica e Relações Internacionais,Tempo e Clima,Tecnologia e Startups

# Formatos separados por vírgula
FORMATS=Artigos e notícias,Papers acadêmicos,Vídeos e podcasts

# Quantidade de itens no digest (padrão: 12 — recomendado 15 com 10 tópicos)
ITEM_QTY=12

# Idioma do digest: pt | en | bilingual (padrão: bilingual)
DIGEST_LANG=bilingual
